{
    UE_LOG(LogGauntletTest, Log, TEXT("%s"), *Message);
}

void U<FEATURE>TestController::LogTestWarning(const FString& Message)
{
    UE_LOG(LogGauntletTest, Warning, TEXT("%s"), *Message);
}

void U<FEATURE>TestController::LogTestError(const FString& Message)
{
    UE_LOG(LogGauntletTest, Error, TEXT("%s"), *Message);
}
